# === Database ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/konnit

# === Backend API ===
NODE_ENV=development
PORT_API=4000
SESSION_SECRET=change-me-to-a-long-random-secret
CORS_ORIGINS=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:3000
GOOGLE_CLIENT_ID=

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_USE_MOCK=false

# === Seed admin (used by db:seed) ===
ADMIN_SEED_EMAIL=admin@konnit.local
ADMIN_SEED_PASSWORD=Admin@123456
ADMIN_SEED_NAME=Konnit Admin

# === Order processing and cache ===
ORDER_HOLD_MINUTES=15
TRANSFER_HOLD_HOURS=24
REDIS_URL=redis://localhost:6379
PUBLIC_TICKETS_CACHE_TTL_SECONDS=30

# === VNPay sandbox ===
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:4000/api/public/payments/vnpay/return
VNPAY_IPN_URL=http://localhost:4000/api/public/payments/vnpay/ipn

# === Email ===
# Leave SMTP_HOST empty in development to use the fallback transport.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Konnit <noreply@konnit.local>

# === Optional Playwright user-guide capture ===
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_API_URL=http://localhost:4000
PLAYWRIGHT_ADMIN_EMAIL=admin@konnit.local
PLAYWRIGHT_ADMIN_PASSWORD=Admin@123456
CAPTURE_USER_GUIDE_CUSTOMER_AUTH=0
