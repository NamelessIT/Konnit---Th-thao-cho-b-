# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/konnit

# === Backend API ===
PORT_API=4000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-secret
CORS_ORIGINS=http://localhost:3000
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# === Frontend ===
PORT_WEB=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_SITE_URL=https://konnit.vn
# NEXT_PUBLIC_API_URL=https://api.konnit.vn

# === Seed Admin (used by db:seed) ===
ADMIN_SEED_EMAIL=admin@konnit.local
ADMIN_SEED_PASSWORD=Admin@123456
ADMIN_SEED_NAME=Konnit Admin

# === Google Identity Services ===
# Web OAuth client ID from Google Auth Platform > Clients.
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# === Public web URL (redirect/return targets) ===
PUBLIC_WEB_URL=http://localhost:3000

# === Order processing ===
# Minutes a pending order holds reserved slots before auto-release
ORDER_HOLD_MINUTES=15
REDIS_URL=redis://localhost:6379
PUBLIC_TICKETS_CACHE_TTL_SECONDS=30

# === VNPay Sandbox ===
# Register a sandbox merchant at https://sandbox.vnpayment.vn to obtain these.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:4000/api/public/payments/vnpay/return
VNPAY_IPN_URL=http://localhost:4000/api/public/payments/vnpay/ipn
