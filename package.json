{
  "name": "konnit",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:api": "pnpm --filter @konnit/api dev",
    "dev:web": "pnpm --filter @konnit/web dev",
    "db:init": "pnpm --filter @konnit/api db:init",
    "db:seed": "pnpm --filter @konnit/api db:seed",
    "test": "turbo run test",
    "test:api": "pnpm --filter @konnit/api test",
    "test:web": "pnpm --filter @konnit/web test"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
